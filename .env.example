# ── GitHub OAuth Apps ─────────────────────────────────────────────────────────
# Butuh DUA OAuth App terpisah di GitHub karena callback URL-nya berbeda.
#
# OAuth App 1 — MCP Server
#   Callback URL: http://localhost:8000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
#
# OAuth App 2 — Platform
#   Callback URL: http://localhost/auth/callback
PLATFORM_GITHUB_CLIENT_ID=
PLATFORM_GITHUB_CLIENT_SECRET=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://rejeki:rejeki@postgres:5432/rejeki

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_BASE_URL=http://localhost:8000

# ── Platform Backend ──────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# URL frontend untuk CORS (production: ganti ke domain kamu)
FRONTEND_URL=http://localhost
