# MCP server URL (where Nginx proxies /rejeki/mcp/)
MCP_BASE_URL=https://your-domain.com/rejeki/mcp

# Auth server URL (where Nginx proxies /rejeki/auth/)
AS_BASE_URL=https://your-domain.com/rejeki/auth

# Internal introspect endpoint (auth server must be running)
INTROSPECT_URL=http://127.0.0.1:9004/introspect

# Path to users.json (username → password + db_path)
USERS_CONFIG=/path/to/rejeki-mcp-server/users.json

# MCP server port
PORT=8001

# Auth server port
AUTH_PORT=9004

# --- Development / evaluation only ---
# TEST_TOKEN=eval-token-secret-123
# TEST_DB=./users/test.db
